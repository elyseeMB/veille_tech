{
  "name": "veille-tech",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localEnv:USERPROFILE}\\.aws,target=/root/.aws,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.gopath": "/go"
      }
    }
  },
  "postCreateCommand": "go work sync",
  "forwardPorts": [8080, 8081, 5432],
  "remoteEnv": {
    "GOPATH": "/go",
    "GOROOT": "/usr/local/go",
    "AWS_PAGER": ""
  }
}
